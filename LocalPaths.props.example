<Project>
  <PropertyGroup>
    <!--
      Copy this file to LocalPaths.props and fill in YOUR local paths.
      LocalPaths.props is gitignored and must never be committed.
    -->
    <SulfurManagedDir>D:\SteamLibrary\steamapps\common\SULFUR\Sulfur_Data\Managed</SulfurManagedDir>
    <BepInExCoreDir>C:\Users\YourName\AppData\Roaming\com.kesomannen.gale\sulfur\profiles\Default\BepInEx\core</BepInExCoreDir>

    <!-- Deploy destination(s). Point at the …\plugins dir of the Gale profile you actually run; the build
         appends "\SULFUR Together" (with the space — that is the folder BepInEx loads) on every build. -->
    <BepInExPluginDir>C:\Users\YourName\AppData\Roaming\com.kesomannen.gale\sulfur\profiles\Default\BepInEx\plugins</BepInExPluginDir>

    <!-- OPTIONAL second destination (e.g. a Sandboxie copy of the same profile, for the second game instance).
         Leave empty / delete the line if you don't run a sandboxed client. -->
    <!-- <BepInExPluginDirSandbox>C:\Sandbox\YourName\DefaultBox\user\current\AppData\Roaming\com.kesomannen.gale\sulfur\profiles\Default\BepInEx\plugins</BepInExPluginDirSandbox> -->

    <!-- OPTIONAL: SULFUR Native UI Lib DLL, for the in-game connect UI / toasts. Compile-time only; the
         runtime dependency stays soft (the mod runs without the lib, just without its UI surfaces). Point at
         the installed plugin's DLL. If unset, the in-game UI source is excluded from the build. -->
    <!-- <NativeUiLibDll>C:\Users\YourName\AppData\Roaming\com.kesomannen.gale\sulfur\profiles\Default\BepInEx\plugins\ryuka_labs-SULFUR_Native_UI_Lib\SULFUR Native UI Lib.dll</NativeUiLibDll> -->
  </PropertyGroup>
</Project>
