# Local decompile scratch (not for commit)
.scratch/

# Release package artifacts refreshed by the build (csproj CopyToRelease target on a Release build):
# the plugin DLL + LiteNetLib, the copied lang/ files, and any packaged zip are all generated and never
# committed. Only the icon/manifest/README/CHANGELOG stay tracked.
Thunderstore/**/*.dll
Thunderstore/lang/
Thunderstore/*.zip
